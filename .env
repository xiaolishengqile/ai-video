# ---------- 对外端口 ----------
APP_PORT=8080

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_fusion_video

# ---------- Redis ----------
REDIS_PASSWORD=123456

# ---------- 后端 JVM ----------
JAVA_OPTS=-Xms512m -Xmx1024m
